class Solution {
public:
    int myAtoi(string s) {
        int i = 0, n = s.size();
        long long result = 0;
        int sign = 1;

        // Skip leading spaces
        while (i < n && s[i] == ' ')
            i++;

        // Handle sign
        if (i < n && (s[i] == '+' || s[i] == '-')) {
            if (s[i] == '-')
                sign = -1;
            i++;
        }

        // Process digits
        while (i < n && isdigit(s[i])) {
            result = result * 10 + (s[i] - '0');

            if (sign * result <= INT_MIN)
                return INT_MIN;
            if (sign * result >= INT_MAX)
                return INT_MAX;

            i++;
        }

        return sign * result;
    }
};
